{
  "name": "pristine",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "dev:web": "vite --config vite.config.web.ts",
    "build": "vite build",
    "preview": "vite build && electron .",
    "package": "vite build && electron-builder --config electron-builder.yml",
    "package:win": "vite build && electron-builder --win --config electron-builder.yml",
    "package:linux": "vite build && electron-builder --linux --config electron-builder.yml",
    "package:mac": "vite build && electron-builder --mac --config electron-builder.yml",
    "test": "vitest",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "lucide-react": "0.487.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-resizable-panels": "2.1.7"
  },
  "devDependencies": {
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@playwright/test": "^1.48.0",
    "@tailwindcss/vite": "4.1.12",
    "@types/node": "^25.5.0",
    "@vitejs/plugin-react": "4.7.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "jsdom": "^29.0.1",
    "tailwindcss": "4.1.12",
    "typescript": "^5.6.0",
    "vite": "6.3.5",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.0",
    "vitest": "^2.1.0"
  },
  "pnpm": {
    "overrides": {
      "vite": "6.3.5"
    },
    "onlyBuiltDependencies": [
      "@tailwindcss/oxide",
      "electron",
      "esbuild"
    ]
  }
}