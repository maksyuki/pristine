{
  "name": "pristine",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "dev:web": "vite --config vite.config.web.ts",
    "build": "vite build",
    "preview": "vite build && electron .",
    "package": "vite build && electron-builder --config electron-builder.yml",
    "package:win": "vite build && electron-builder --win --config electron-builder.yml",
    "package:linux": "vite build && electron-builder --linux --config electron-builder.yml",
    "package:mac": "vite build && electron-builder --mac --config electron-builder.yml",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json && tsc --noEmit -p tsconfig.node.json",
    "test": "vitest",
    "test:unit": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@irojs/iro-core": "^1.2.1",
    "@monaco-editor/react": "^4.7.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "ignore": "^7.0.5",
    "konva": "^10.2.3",
    "lucide-react": "0.487.0",
    "node-pty": "^1.1.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-konva": "^19.2.3",
    "react-resizable-panels": "2.1.9",
    "remixicon": "^4.9.1"
  },
  "devDependencies": {
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@playwright/test": "^1.48.0",
    "@tailwindcss/vite": "4.1.12",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "5.2.0",
    "@vitest/coverage-v8": "^2.1.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "jsdom": "^29.0.1",
    "tailwindcss": "4.1.12",
    "typescript": "^5.6.0",
    "vite": "6.3.5",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.0",
    "vitest": "^2.1.0"
  },
  "pnpm": {
    "overrides": {
      "vite": "6.3.5"
    },
    "onlyBuiltDependencies": [
      "@tailwindcss/oxide",
      "electron",
      "esbuild",
      "node-pty"
    ]
  }
}